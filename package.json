{
  "name": "grapher",
  "type": "module",
  "version": "1.0.0",
  "author": {
    "name": "ronz"
  },
  "description": "A GraphQL query builder for TypeScript.",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bunup",
    "test": "vitest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bunup": "^0.16.31",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "graphql": "^16.14.0",
    "typescript": "^5"
  }
}
